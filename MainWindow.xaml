<Window x:Class="TilePinger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TilePinger" Height="450" Width="800">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <TextBox x:Name="NameText" Width="150" Margin="4" ToolTip="Name" />
            <TextBox x:Name="HostText" Width="150" Margin="4" ToolTip="Host" />
            <Button Content="Add" Click="AddButton_Click" Margin="4" />
        </StackPanel>
        <ScrollViewer>
            <ItemsControl x:Name="ServerItems">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="16" Margin="8" Padding="12" BorderThickness="1" BorderBrush="LightGray" Background="{Binding Background}">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Host}" FontSize="12" Foreground="DimGray" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Status}" FontSize="14" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Roundtrip}" FontSize="12" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
